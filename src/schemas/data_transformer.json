{
  "name": "data_transformer",
  "description": "Transform CSV and JSON data: filter, sort, add fields (LLM-powered), and convert between formats.",
  "actions": {
    "filter": {
      "description": "Filter rows matching conditions with AND/OR logic. Supports: eq, neq, contains, startsWith, endsWith (case-insensitive), gt, lt, gte, lte (lexicographic).",
      "parameters": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "Absolute path to a CSV or JSON file"
          },
          "format": {
            "type": "string",
            "enum": ["csv", "json"],
            "description": "Format of the source file"
          },
          "conditions": {
            "type": "array",
            "description": "Filter conditions",
            "items": {
              "type": "object",
              "properties": {
                "field": { "type": "string", "description": "Field/column name" },
                "op": {
                  "type": "string",
                  "enum": ["eq", "neq", "contains", "startsWith", "endsWith", "gt", "lt", "gte", "lte"],
                  "description": "Comparison operator"
                },
                "value": { "type": "string", "description": "Value to compare against" }
              },
              "required": ["field", "op", "value"],
              "additionalProperties": false
            }
          },
          "logic": {
            "type": "string",
            "enum": ["and", "or"],
            "description": "How to combine conditions: 'and' (all must match) or 'or' (any must match)"
          }
        },
        "required": ["path", "format", "conditions", "logic"],
        "additionalProperties": false
      }
    },
    "sort": {
      "description": "Sort rows by one or more fields. Supports ascending/descending and numeric-aware comparison.",
      "parameters": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "Absolute path to a CSV or JSON file"
          },
          "format": {
            "type": "string",
            "enum": ["csv", "json"],
            "description": "Format of the source file"
          },
          "sort_by": {
            "type": "array",
            "description": "Sort criteria (applied in order for multi-field sort)",
            "items": {
              "type": "object",
              "properties": {
                "field": { "type": "string", "description": "Field/column name to sort by" },
                "direction": {
                  "type": "string",
                  "enum": ["asc", "desc"],
                  "description": "Sort direction"
                }
              },
              "required": ["field", "direction"],
              "additionalProperties": false
            }
          }
        },
        "required": ["path", "format", "sort_by"],
        "additionalProperties": false
      }
    },
    "add_field": {
      "description": "Generate a new field using LLM (via batchTransform). Each row is processed with context from selected fields.",
      "parameters": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "Absolute path to a CSV or JSON file"
          },
          "format": {
            "type": "string",
            "enum": ["csv", "json"],
            "description": "Format of the source file"
          },
          "field_name": {
            "type": "string",
            "description": "Name of the new field to add"
          },
          "instructions": {
            "type": "string",
            "description": "Natural-language instructions for generating the field value"
          },
          "context_fields": {
            "type": "array",
            "description": "Fields to include as context for the LLM (sent as 'field: value' pairs)",
            "items": {
              "type": "string"
            }
          }
        },
        "required": ["path", "format", "field_name", "instructions", "context_fields"],
        "additionalProperties": false
      }
    },
    "convert": {
      "description": "Convert between CSV and JSON. Optionally remap column/key names with type coercion (string, number, json).",
      "parameters": {
        "type": "object",
        "properties": {
          "source_path": {
            "type": "string",
            "description": "Absolute path to the source file"
          },
          "from_format": {
            "type": "string",
            "enum": ["csv", "json"],
            "description": "Format of the source file"
          },
          "to_format": {
            "type": "string",
            "enum": ["csv", "json"],
            "description": "Desired output format"
          },
          "mapping": {
            "type": "array",
            "description": "Column/key mapping. Empty array [] for passthrough.",
            "items": {
              "type": "object",
              "properties": {
                "from": { "type": "string", "description": "Source column/key name" },
                "to": { "type": "string", "description": "Output column/key name" },
                "type": {
                  "type": "string",
                  "enum": ["string", "number", "json"],
                  "description": "Type coercion (CSV→JSON only): string (default), number, json"
                }
              },
              "required": ["from", "to", "type"],
              "additionalProperties": false
            }
          }
        },
        "required": ["source_path", "from_format", "to_format", "mapping"],
        "additionalProperties": false
      }
    }
  }
}
