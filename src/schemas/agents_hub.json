{
  "name": "agents_hub",
  "description": "Interact with the AG3NTS hub. Use action to pick an operation: download (fetch a file by name from hub.ag3nts.org), verify (submit an answer for verification), api_request (POST to any /api/* endpoint).",
  "parameters": {
    "type": "object",
    "oneOf": [
      {
        "properties": {
          "action": { "const": "download" },
          "payload": {
            "type": "object",
            "properties": {
              "filename": {
                "type": "string",
                "description": "Name of the file to download (e.g. \"people.csv\", \"xyz.json\")"
              }
            },
            "required": ["filename"],
            "additionalProperties": false
          }
        },
        "required": ["action", "payload"]
      },
      {
        "properties": {
          "action": { "const": "verify" },
          "payload": {
            "type": "object",
            "properties": {
              "task": {
                "type": "string",
                "description": "The task name to verify against (e.g. \"people\")"
              },
              "answer_file": {
                "type": "string",
                "description": "Absolute path to the JSON file containing the answer data"
              }
            },
            "required": ["task", "answer_file"],
            "additionalProperties": false
          }
        },
        "required": ["action", "payload"]
      },
      {
        "properties": {
          "action": { "const": "api_request" },
          "payload": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string",
                "description": "API path segment after /api/ (e.g. \"location\", \"users/search\")"
              },
              "body": {
                "type": "object",
                "description": "Inline JSON body to send (mutually exclusive with body_file)"
              },
              "body_file": {
                "type": "string",
                "description": "Absolute path to a JSON file whose contents will be used as the request body (mutually exclusive with body)"
              }
            },
            "required": ["path"],
            "additionalProperties": false
          }
        },
        "required": ["action", "payload"]
      }
    ],
    "additionalProperties": false
  }
}
