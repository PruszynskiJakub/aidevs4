# Environment: "development" (default) or "production"
NODE_ENV=development

# Required
HUB_API_KEY=XYZ
OPENAI_API_KEY=XYZ

# Optional APIs
GEMINI_API_KEY=XYZ
SERPER_API_KEY=XYZ

# Langfuse — tracing is enabled when both keys are set
LANGFUSE_PUBLIC_KEY=XYZ
LANGFUSE_SECRET_KEY=XYZ
LANGFUSE_BASE_URL=https://cloud.langfuse.com
# Defaults to NODE_ENV value if not set
# LANGFUSE_ENVIRONMENT=development

# Database — defaults to ./data/dev.db (dev) or ./data/prod.db (prod)
# DATABASE_URL=./data/dev.db

# Server
# PORT=3000
# API_SECRET=XYZ

# Slack bot
SLACK_BOT_TOKEN=XYZ
SLACK_APP_TOKEN=XYZ

# Browser
# BROWSER_HEADLESS=true
